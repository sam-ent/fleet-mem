# ChromaDB storage path
# CHROMA_PATH=~/.local/share/fleet-mem/chroma

# Ollama connection
# Default works for systemd/brew Ollama installs
# OLLAMA_HOST=http://localhost:11434
# For Docker: OLLAMA_HOST=http://localhost:11434
# For Docker Compose service: OLLAMA_HOST=http://ollama:11434

# Embedding model (must be pulled in Ollama)
# OLLAMA_EMBED_MODEL=nomic-embed-text

# Memory database
# MEMORY_DB_PATH=~/.local/share/fleet-mem/memory.db

# Fleet coordination database (locks, subscriptions)
# FLEET_DB_PATH=~/.local/share/fleet-mem/fleet.db

# Background sync interval (seconds)
# SYNC_INTERVAL=300

# Embedding provider: "ollama" (default, free, local) or "openai-compat" (any OpenAI-compatible API)
# EMBEDDING_PROVIDER=ollama

# For openai-compat provider:
# EMBED_API_KEY=sk-...
# EMBED_BASE_URL=https://api.openai.com/v1
# EMBED_MODEL=text-embedding-3-small

# Common provider base URLs:
# OpenAI:    https://api.openai.com/v1
# DeepSeek:  https://api.deepseek.com/v1
# Together:  https://api.together.xyz/v1
# Fireworks: https://api.fireworks.ai/inference/v1
# Local vLLM: http://localhost:8000/v1

# ChromaDB telemetry (always disabled)
ANONYMIZED_TELEMETRY=False
